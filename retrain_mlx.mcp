#!/usr/bin/env python3
"""
MCP Skill: retrain_mlx
Description: Triggers the Apple MLX LoRA local fine-tuning with dynamic iterations.
Usage: python3 retrain_mlx.mcp <data_dir> <output_adapter_dir> [iters]
"""
import sys
import subprocess
import os

BASE_MODEL = "mlx-community/Mistral-7B-Instruct-v0.3-4bit"

def main():
    if len(sys.argv) < 3:
        print("Usage: python3 retrain_mlx.mcp <mlx_data_dir> <output_adapter_dir> [iters]")
        sys.exit(1)
        
    data_dir = sys.argv[1]
    adapter_dir = sys.argv[2]
    
    # Parse dynamic iterations (default: 100, clamped safely between 10 and 1000)
    # A 7B parameter model usually requires ~500-1000 max updates for a tiny dataset 
    # before catastrophic forgetting destroys its baseline capabilities.
    iters = 100
    if len(sys.argv) >= 4:
        try:
            iters = max(10, min(int(sys.argv[3]), 1000))
        except ValueError:
            print("[MCP] WARNING: Invalid iteration syntax. Defaulting to 100.")
    
    if not os.path.exists(data_dir):
        print(f"Error: training directory {data_dir} does not exist.")
        sys.exit(1)
        
    print(f"[MCP] Starting local MLX LoRA training on {BASE_MODEL}...")
    print(f"[MCP] Data: {data_dir} -> Output: {adapter_dir} -> Iters: {iters}")
    
    cmd = [
        "python3", "-m", "mlx_lm.lora",
        "--model", BASE_MODEL,
        "--train",
        "--data", data_dir,
        "--iters", str(iters),
        "--learning-rate", "2e-5",
        "--adapter-path", adapter_dir,
        "--report-to", "wandb",
        "--project-name", "mistral-hackathon"
    ]
    
    try:
        subprocess.run(cmd, check=True)
        print(f"\n[MCP] Retraining complete! Adapter saved to {adapter_dir}")
    except subprocess.CalledProcessError as e:
        print(f"\n[MCP] Training failed with exit code {e.returncode}")
        sys.exit(1)

if __name__ == "__main__":
    main()
